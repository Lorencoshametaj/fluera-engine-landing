---
import { SITE } from "@/lib/site";
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(href + "/");
---

<header class="fixed inset-x-0 top-0 z-40 border-b border-white/[0.04] bg-ink-950/80 backdrop-blur-md">
  <div class="container-site flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-2.5 font-serif text-lg text-paper-50 hover:text-white">
      <img src="/favicon.png" alt="" width="24" height="24" class="rounded-sm" />
      <span>Fluera <span class="text-paper-300">Engine</span></span>
    </a>

    <nav class="flex items-center gap-1 sm:gap-2" aria-label="Primary">
      <a
        href="/quickstart"
        class:list={[
          "btn-ghost text-sm",
          isActive("/quickstart") ? "text-paper-50" : "",
        ]}
      >
        Quickstart
      </a>
      <a
        href="/compare"
        class:list={[
          "btn-ghost text-sm",
          isActive("/compare") ? "text-paper-50" : "",
        ]}
      >
        Compare
      </a>
      <a
        href="/pricing"
        class:list={[
          "btn-ghost text-sm",
          isActive("/pricing") ? "text-paper-50" : "",
        ]}
      >
        Pricing
      </a>
      <a
        href={SITE.github}
        target="_blank"
        rel="noopener"
        class="btn-secondary text-sm ml-1"
      >
        GitHub
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M7 17L17 7M17 7H8M17 7V16"/>
        </svg>
      </a>
    </nav>
  </div>
</header>
